# ============================================================
#  nl2sql_RAG_app  —  Environment Variables  (.env.example)
# ============================================================
#
#  HOW TO USE:
#  -----------
#  Option A (recommended — project-specific key):
#    1. Copy this file:   cp .env.example .env
#    2. Fill in your key: OPENAI_API_KEY=sk-...
#    3. This project's .env always takes highest priority.
#
#  Option B (reuse an existing project's key automatically):
#    Do NOT create a .env file here.
#    config.py will automatically load from:
#      ~/Dropbox/LegalApp/.env   (if it exists)
#      ~/Dropbox/LegalDocs/.env  (fallback)
#    No action needed — it just works.
#
#  Option C (shell export):
#    export OPENAI_API_KEY=sk-...
#    (used if no .env file is found anywhere)
#
#  SECURITY:
#    • .env  is listed in .gitignore — it will NEVER be committed.
#    • Only .env.example  (this file, no real keys) is safe to commit.
# ============================================================

# Required when USE_OPENAI = True or USE_OPENAI_EMBEDDINGS = True
OPENAI_API_KEY=sk-your-key-here

# Optional overrides (uncomment to override config.py defaults)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
